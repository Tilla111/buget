GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090

# k6 frontend page target
LOAD_TEST_URL=https://example.com
LOAD_REQUEST_METHOD=GET
LOAD_REQUEST_HEADERS={"Accept":"text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8","User-Agent":"k6-frontend-load/1.0"}
LOAD_REQUEST_BODY=
LOAD_REQUEST_TIMEOUT=60s
LOAD_EXPECTED_STATUS_CODES=200,301,302,304
LOAD_MODE=ramp
LOAD_START_RATE=20
LOAD_STAGES=50:1m,100:1m,150:1m,200:1m,250:1m,300:1m
LOAD_RATE=300
LOAD_DURATION=2m
LOAD_PRE_ALLOCATED_VUS=500
LOAD_MAX_VUS=2500
LOAD_ACCEPTABLE_P95_MS=1200
LOAD_ACCEPTABLE_ERROR_RATE=0.01
LOAD_INCLUDE_PAGE_ASSETS=true
LOAD_INCLUDE_PAGE_IMAGES=false
LOAD_MAX_PAGE_ASSETS=24
LOAD_PAGE_ASSET_HOSTS=cdn.example.com
LOAD_ACCEPTABLE_PAGE_P95_MS=5000

# Playwright frontend flow target
PAGE_URL=https://example.com
PAGE_URLS=https://example.com,https://example.com/about
LOOP_COUNT=10
LOOP_DELAY_MS=1000
FRONTEND_ROUTE_DELAY_MS=300
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_VIDEO=retain-on-failure
PLAYWRIGHT_SCREENSHOT=only-on-failure
PLAYWRIGHT_TRACE=retain-on-failure
PLAYWRIGHT_CAPTURE_EVERY_N=10
FRONTEND_SETTLE_MS=1500
FRONTEND_MAX_TTFB_MS=800
FRONTEND_MAX_FCP_MS=1800
FRONTEND_MAX_LCP_MS=2500
FRONTEND_MAX_LOAD_MS=5000
FRONTEND_MAX_CLS=0.1
FRONTEND_MAX_TOTAL_BLOCKING_TIME_MS=200
FRONTEND_MAX_FAILED_REQUESTS=0
FRONTEND_MAX_HTTP_ERRORS=0
FRONTEND_MAX_PAGE_ERRORS=0
