GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090

# k6 load target
LOAD_TEST_URL=https://example.com/api/health
LOAD_REQUEST_METHOD=GET
LOAD_REQUEST_HEADERS={"Accept":"application/json","Authorization":"Bearer <token>"}
LOAD_REQUEST_BODY=
LOAD_REQUEST_TIMEOUT=60s
LOAD_EXPECTED_STATUS_CODES=200,301,302,304
LOAD_MODE=ramp
LOAD_START_RATE=100
LOAD_STAGES=200:1m,500:1m,1000:1m,2000:1m,3500:1m,5000:1m
LOAD_RATE=5000
LOAD_DURATION=2m
LOAD_PRE_ALLOCATED_VUS=200
LOAD_MAX_VUS=500
LOAD_ACCEPTABLE_P95_MS=800
LOAD_ACCEPTABLE_ERROR_RATE=0.01

# Playwright UI loop target
PAGE_URL=https://example.com
LOOP_COUNT=20
LOOP_DELAY_MS=1000
PLAYWRIGHT_HEADLESS=true
